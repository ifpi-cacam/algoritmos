algoritmo "semnome"
// Funçăo : construa um algoritmo para receber o valor real de
// N calcular e mostrar N ao quadrado
// Autor : Nairon Viana
// Data : 09/04/2026
// Seçăo de Declaraçőes 
var
   n, q: real
inicio
// Seçăo de Comandos 
   escreval("Digite o valor de N: ")
   leia(n)
   q <- Exp(n, 2)
   escreval("O quadrado de ", n, " é: ", q)
fimalgoritmo

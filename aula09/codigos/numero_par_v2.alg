algoritmo "numero_par_v2"
// Função : Recebe um número inteiro, mostra se o número é ímpar ou par
// Autor : Nairon Viana
// Data : 23/04/2026
// Seção de Declarações
var
  n: inteiro
inicio
// Seção de Comandos
escreval("Digite o número")
leia(n)
se (n mod 2 = 0) entao
  escreval(n, " é par!")
senao
  escreval(n, " é ímpar")
fimse

fimalgoritmo
